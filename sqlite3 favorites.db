CREATE TABLE IF NOT EXISTS recipe_pool (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    meal_type TEXT NOT NULL,   -- "dinner" / "breakfast,lunch" など
    role TEXT NOT NULL,        -- "main" or "side"
    tags TEXT,                 -- "和食,スープ,ダイエット"
    months TEXT,               -- "1,2,3"
    ingredients TEXT,          -- "玉ねぎ, にんじん"
    allergy_flags TEXT,        -- "卵,乳"
    kcal REAL,
    protein REAL,
    fat REAL,
    carbs REAL,
    cook_time_min REAL,
    used INTEGER NOT NULL DEFAULT 0
);
.exit
